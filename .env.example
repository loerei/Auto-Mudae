# Copy to `.env` (or `config.env`) and edit values.
# OS environment variables override values from this file.
# All IDs and usernames below are placeholders.

# Core IDs
#CHANNEL_ID=123456789012345678
#SERVER_ID=234567890123456789

# Tokens list (JSON)
# TOKENS_JSON=[
#   {
#     "id": 1,
#     "discord_user_id": "345678901234567890",
#     "name": "PlayerOne",
#     "discordusername": "player_one",
#     "token": "PASTE_USER_TOKEN_1",
#     "max_power": 110
#   },
#   {
#     "id": 2,
#     "discord_user_id": "456789012345678901",
#     "name": "PlayerTwo",
#     "discordusername": "player_two",
#     "token": "PASTE_USER_TOKEN_2",
#     "max_power": 110
#   }
# ]

# Optional mappings (JSON arrays)
# KAKERA_GIVE=[[1,2]]
# SPHERE_GIVE=[[1,2]]

# Common overrides
# ROLL_COMMAND=wx
# POKE_ROLL=false
# MIN_KAKERA_TO_CLAIM=200
# KAKERA_PRIORITY={
#   "kakerap": null,
#   "kakerac": null,
#   "kakeral": null,
#   "kakeraw": null,
#   "kakerar": null,
#   "kakerao": null,
#   "kakerad": null,
#   "kakeray": null,
#   "kakerag": null,
#   "kakerat": null,
#   "kakerab": null,
#   "kakera": null
# }
# Example partial override: {"kakerag":0,"kakerat":0}
# WISHLIST=["Arknights: Endfield","K-ON!"]
# STEAL_CLAIM_WHITELIST=[]
# STEAL_REACT_WHITELIST=["username_a","username_b"]
